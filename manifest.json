{
  "manifest_version": 3,
  "name": "Testocan",
  "version": "0.3.0",
  "key": "",
  "description": "Yapay zeka destekli otonom web kalite güvence asistanınız.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "debugger",
    "tabs",
    "notifications",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>",
    "file:///*/*"
  ],

  "background": {
    "service_worker": "src/background/index.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*/*"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["src/content/injected.js", "icons/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
